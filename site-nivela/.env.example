# GitHub OAuth App usado pelo Decap CMS.
# Crie um arquivo .env.local com estes mesmos nomes e preencha os valores reais
GITHUB_CLIENT_ID=coloque_o_client_id_aqui
GITHUB_CLIENT_SECRET=coloque_o_client_secret_aqui

# Use 1 quando o repositorio for privado, para pedir o escopo repo no GitHub
# Use 0 somente se o repositorio for publico.
GITHUB_REPO_PRIVATE=1

# Configurações de e-mail para envio de mensagens do formulário de contato via Nodemailer.
# E-mail que vai enviar as notificações
EMAIL_USER=email@seu-dominio.com

# Senha do e-mail (Senha de App se for Gmail, ou senha comum de SMTP)
EMAIL_PASS=sua_senha_ou_token_de_app

# Servidor SMTP do provedor (ex: smtp.gmail.com se for Gmail)
EMAIL_HOST=smtp.seu-provedor.com.br

# Porta de conexão segura (geralmente 465 para SSL ou 587 para TLS)
EMAIL_PORT=porta

# Segurança da conexão (true para porta 465, false para 587)
EMAIL_SECURE=true_ou_false

# E-mail que recebera as mensagens (geralmente o mesmo do EMAIL_USER)
EMAIL_DESTINATION=email@seu-dominio.com
